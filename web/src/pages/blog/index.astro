---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<Layout title="Blog — Matthew Windham" description="Writing on DevOps, AWS, infrastructure automation, and engineering.">
	<main>
		<div class="wrap">
			<h1 class="page-title">Blog</h1>
			{posts.length === 0 ? (
				<p class="empty">No posts yet — check back soon.</p>
			) : (
				<ul class="post-list">
					{posts.map(post => (
						<li class="post-item">
							<a href={`/blog/${post.id}`} class="post-link">
								<span class="post-title">{post.data.title}</span>
								<time class="post-date" datetime={post.data.date.toISOString()}>
									{fmt.format(post.data.date)}
								</time>
							</a>
							<p class="post-desc">{post.data.description}</p>
						</li>
					))}
				</ul>
			)}
		</div>
	</main>
</Layout>

<style>
	.page-title {
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 2.5rem;
		color: #fff;
		border-bottom: none;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.post-item {
		border-bottom: 1px solid var(--border);
		padding-bottom: 2.5rem;
	}

	.post-item:last-child {
		border-bottom: none;
	}

	.post-link {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 0.6rem;
		color: var(--text);
	}

	.post-link:hover {
		text-decoration: none;
	}

	.post-link:hover .post-title {
		color: var(--accent);
	}

	.post-title {
		font-size: 1.2rem;
		font-weight: 600;
		transition: color 0.15s;
	}

	.post-date {
		font-family: var(--mono);
		font-size: 0.82rem;
		color: var(--text-dim);
		white-space: nowrap;
	}

	.post-desc {
		color: var(--text-dim);
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.empty {
		color: var(--text-dim);
	}
</style>
