					</svg>
					<span>GitHub</span>
				</a>
				<a
					href="https://www.linkedin.com/in/matthew-windham-58b29757/"
					target="_blank"
					rel="noopener"
					aria-label="LinkedIn"
				>
					<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
