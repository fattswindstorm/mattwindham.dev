				<a
					href="https://github.com/fattswindstorm/mattwindham.dev"
					target="_blank"
					rel="noopener"
					aria-label="Source for this site"
				>
					<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
						<path d="M4.72 3.22a.75.75 0 0 1 0 1.06L1.81 7l2.91 2.72a.75.75 0 1 1-1.06 1.06L.3 7.53a.75.75 0 0 1 0-1.06l3.36-3.25a.75.75 0 0 1 1.06 0Zm6.56 0a.75.75 0 0 1 1.06 0l3.36 3.25a.75.75 0 0 1 0 1.06l-3.36 3.25a.75.75 0 1 1-1.06-1.06L14.19 7l-2.91-2.72a.75.75 0 0 1 0-1.06ZM9.13 1.78a.75.75 0 0 1 .5.94l-3 11a.75.75 0 1 1-1.45-.4l3-11a.75.75 0 0 1 .95-.54Z" />
