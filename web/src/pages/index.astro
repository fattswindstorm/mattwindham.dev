					</svg>
					<span>LinkedIn</span>
				</a>
				<a href="mailto:windham.matt@gmail.com" aria-label="Email">
					<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
						<path d="M1 4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4Zm1.2.1 5.6 4.2a.5.5 0 0 0 .6 0l5.6-4.2.06-.1H2.13Zm10.92.79-5.5 4.13a1.5 1.5 0 0 1-1.84 0L2.28 4.89 2 5.1V12h12V5.1l-.28-.2Z" />
					</svg>
