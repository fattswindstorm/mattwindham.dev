---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Matthew Windham - DevOps Engineer"
	description="DevOps / Site Reliability Engineer specializing in AWS, Terraform, and infrastructure automation."
>
	<header class="hero">
		<div class="glow" aria-hidden="true"></div>
		<div class="hero-inner">
		<div class="wrap hero-content">
