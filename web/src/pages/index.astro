		</div>
		</div>
	</header>
</Layout>

<style>
	.hero {
		position: relative;
		min-height: calc(100vh - 70px);
		display: grid;
		align-content: center;
		overflow: hidden;
	}

	.hero-inner {
		width: 100%;
	}

	.glow {
		position: absolute;
		top: -20%;
		right: -10%;
		width: 60vw;
		height: 60vw;
		max-width: 700px;
		max-height: 700px;
		background: radial-gradient(circle, rgba(255, 153, 0, 0.18), transparent 70%);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
	}

	.eyebrow {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-dim);
		font-family: var(--mono);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 1.25rem;
	}

	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 0 rgba(255, 153, 0, 0.6);
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0% {
			box-shadow: 0 0 0 0 rgba(255, 153, 0, 0.5);
		}
		70% {
			box-shadow: 0 0 0 6px rgba(255, 153, 0, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(255, 153, 0, 0);
		}
	}

	h1 {
		font-size: clamp(3rem, 9vw, 5.5rem);
		line-height: 1.02;
		margin: 0 0 1.5rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: #fff;
	}

	.accent-text {
		color: var(--accent);
	}

	.tagline {
		color: var(--text-dim);
		font-size: 1.2rem;
		max-width: 32ch;
		margin: 0 0 2.5rem;
	}

	.cta-row {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 3rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: 0.7rem 1.5rem;
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.95rem;
		transition: transform 0.15s ease, opacity 0.15s ease;
	}

	.btn:hover {
		text-decoration: none;
		transform: translateY(-2px);
	}

	.btn-primary {
		background: var(--accent);
		color: #0b0e14;
	}

	.btn-primary:hover {
		opacity: 0.9;
	}

	.btn-ghost {
		border: 1px solid var(--border);
		color: var(--text);
	}

	.btn-ghost:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.contact-row {
		display: flex;
		gap: 1.75rem;
		flex-wrap: wrap;
	}

	.contact-row a {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-dim);
		font-size: 0.9rem;
	}

	.contact-row a:hover {
		text-decoration: none;
		color: var(--accent);
	}

	@media (max-width: 600px) {
		.hero {
			min-height: auto;
			padding: 3rem 0;
		}
	}
</style>
