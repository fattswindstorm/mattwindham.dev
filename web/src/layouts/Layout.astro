---
interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = "/avatar.jpg" } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const navLinks = [
	{ href: "/about", label: "About" },
	{ href: "/resume", label: "Resume" },
	{ href: "/projects", label: "Projects" },
	{ href: "/opportunity", label: "Recruiter" },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<title>{title}</title>

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageURL} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />
	</head>
	<body>
		<nav class="site-nav">
			<div class="wrap nav-row">
				<a class="brand" href="/">Matthew Windham</a>
				<button
					type="button"
					class="hamburger"
					id="hamburger"
					aria-label="Open menu"
					aria-expanded="false"
					aria-controls="nav-drawer"
				>
					<span></span><span></span><span></span>
				</button>
			</div>
		</nav>

		<!-- Drawer overlay -->
		<div class="drawer-overlay" id="drawer-overlay" aria-hidden="true"></div>

		<!-- Side drawer -->
		<div class="nav-drawer" id="nav-drawer" aria-hidden="true">
			<div class="drawer-header">
				<span class="drawer-brand">Matthew Windham</span>
				<button type="button" class="drawer-close" id="drawer-close" aria-label="Close menu">
					<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
						<line x1="2" y1="2" x2="16" y2="16" />
						<line x1="16" y1="2" x2="2" y2="16" />
					</svg>
				</button>
			</div>

			<!-- Shown while auth state loads -->
			<div class="drawer-loading" id="drawer-loading">
				<span class="loading-dot"></span>
			</div>

			<!-- Logged-out state -->
			<div class="drawer-guest" id="drawer-guest" hidden>
				<a href="/portal/login" class="drawer-action-btn">Sign In</a>
				<a href="/portal/register" class="drawer-register-link">Create an account</a>
			</div>

			<!-- Logged-in state -->
			<div class="drawer-auth" id="drawer-auth" hidden>
				<p class="drawer-greeting" id="drawer-greeting"></p>
				<nav class="drawer-nav">
					{navLinks.map((link) => (
						<a
							href={link.href}
							class={pathname.startsWith(link.href) ? "active" : ""}
						>
							{link.label}
						</a>
					))}
					<a href="/portal/admin" id="drawer-admin" hidden>Admin</a>
				</nav>
				<button type="button" id="drawer-signout" class="drawer-signout">Sign Out</button>
			</div>
		</div>

		<slot />
		<footer class="wrap">
			<p>Matthew Windham</p>
		</footer>
	</body>
</html>

<script>
	import { getClaims, isAdmin, signOut } from "../lib/auth";

	const hamburger = document.getElementById("hamburger")!;
	const overlay = document.getElementById("drawer-overlay")!;
	const drawer = document.getElementById("nav-drawer")!;
	const closeBtn = document.getElementById("drawer-close")!;

	let authLoaded = false;

	function openDrawer() {
		hamburger.setAttribute("aria-expanded", "true");
		drawer.setAttribute("aria-hidden", "false");
		overlay.classList.add("visible");
		drawer.classList.add("open");
		document.body.classList.add("drawer-open");
		if (!authLoaded) loadAuth();
	}

	function closeDrawer() {
		hamburger.setAttribute("aria-expanded", "false");
		drawer.setAttribute("aria-hidden", "true");
		overlay.classList.remove("visible");
		drawer.classList.remove("open");
		document.body.classList.remove("drawer-open");
	}

	hamburger.addEventListener("click", openDrawer);
	closeBtn.addEventListener("click", closeDrawer);
	overlay.addEventListener("click", closeDrawer);
	document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeDrawer(); });

	async function loadAuth() {
		const loading = document.getElementById("drawer-loading")!;
		const guestEl = document.getElementById("drawer-guest")!;
		const authEl = document.getElementById("drawer-auth")!;
		const greeting = document.getElementById("drawer-greeting")!;
		const adminLink = document.getElementById("drawer-admin") as HTMLAnchorElement;

		const claims = await getClaims();
		loading.hidden = true;

		if (claims) {
			greeting.textContent = claims.name || claims.email || "";
			if (isAdmin(claims)) adminLink.hidden = false;
			authEl.hidden = false;
		} else {
			guestEl.hidden = false;
		}

		document.getElementById("drawer-signout")?.addEventListener("click", () => {
			closeDrawer();
			signOut();
		});

		authLoaded = true;
	}
</script>

<style is:global>
	:root {
		--bg: #0b0e14;
		--bg-raised: #11151d;
		--border: #1f2733;
		--text: #e6e9ef;
		--text-dim: #92a0b3;
		--accent: #ff9900;
		--mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
		--sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
	}

	* { box-sizing: border-box; }

	html, body {
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--sans);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	body.drawer-open {
		overflow: hidden;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover { text-decoration: underline; }

	code { font-family: var(--mono); }

	.wrap {
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ── Nav bar ── */
	.site-nav {
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--bg);
	}

	.nav-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 0;
	}

	.brand {
		color: var(--text);
		font-weight: 600;
	}

	.brand:hover {
		text-decoration: none;
		color: var(--accent);
	}

	/* ── Hamburger ── */
	.hamburger {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.25rem;
		display: flex;
		flex-direction: column;
		gap: 5px;
		align-items: flex-end;
	}

	.hamburger span {
		display: block;
		height: 2px;
		background: var(--text-dim);
		border-radius: 2px;
		transition: background 0.15s;
	}

	.hamburger span:nth-child(1) { width: 22px; }
	.hamburger span:nth-child(2) { width: 16px; }
	.hamburger span:nth-child(3) { width: 22px; }

	.hamburger:hover span { background: var(--accent); }

	/* ── Overlay ── */
	.drawer-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		z-index: 200;
	}

	.drawer-overlay.visible {
		display: block;
	}

	/* ── Drawer ── */
	.nav-drawer {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		width: 280px;
		background: var(--bg-raised);
		border-left: 1px solid var(--border);
		z-index: 300;
		transform: translateX(100%);
		transition: transform 0.25s ease;
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		gap: 1.5rem;
	}

	.nav-drawer.open {
		transform: translateX(0);
	}

	.drawer-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.drawer-brand {
		font-weight: 600;
		color: var(--text);
		font-size: 0.95rem;
	}

	.drawer-close {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--text-dim);
		padding: 0.25rem;
		line-height: 0;
		transition: color 0.15s;
	}

	.drawer-close:hover { color: var(--accent); }

	/* ── Loading dot ── */
	.drawer-loading {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem 0;
	}

	.loading-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent);
		opacity: 0.6;
		animation: pulse 1.2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.3; transform: scale(0.8); }
		50% { opacity: 1; transform: scale(1.1); }
	}

	/* ── Guest state ── */
	.drawer-guest {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-start;
	}

	.drawer-action-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.6rem 1.4rem;
		border-radius: 999px;
		background: var(--accent);
		color: #0b0e14;
		font-weight: 600;
		font-size: 0.95rem;
		transition: opacity 0.15s;
	}

	.drawer-action-btn:hover {
		text-decoration: none;
		opacity: 0.9;
	}

	.drawer-register-link {
		color: var(--text-dim);
		font-size: 0.9rem;
	}

	/* ── Auth state ── */
	.drawer-auth {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.drawer-greeting {
		margin: 0;
		color: var(--text-dim);
		font-size: 0.85rem;
		font-family: var(--mono);
		border-bottom: 1px solid var(--border);
		padding-bottom: 1rem;
	}

	.drawer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.drawer-nav a {
		color: var(--text-dim);
		font-size: 1rem;
		padding: 0.5rem 0.75rem;
		border-radius: 6px;
		transition: background 0.15s, color 0.15s;
	}

	.drawer-nav a:hover {
		text-decoration: none;
		background: var(--border);
		color: var(--text);
	}

	.drawer-nav a.active {
		color: var(--accent);
		background: rgba(255, 153, 0, 0.08);
	}

	.drawer-signout {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--text-dim);
		font-size: 0.9rem;
		padding: 0.5rem 0.75rem;
		text-align: left;
		border-radius: 6px;
		transition: background 0.15s, color 0.15s;
		margin-top: auto;
	}

	.drawer-signout:hover {
		background: var(--border);
		color: var(--text);
	}

	/* ── Page content ── */
	main { padding: 3rem 0; }

	section { margin-bottom: 3rem; }

	h2 {
		font-size: 1.4rem;
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.5rem;
		margin-bottom: 1.5rem;
	}

	blockquote {
		border-left: 2px solid var(--accent);
		margin: 1.5rem 0;
		padding-left: 1rem;
		color: var(--text-dim);
		font-style: italic;
	}

	blockquote cite {
		display: block;
		margin-top: 0.3rem;
		font-style: normal;
		font-size: 0.9rem;
	}

	footer {
		padding: 2rem 0 3rem;
		color: var(--text-dim);
		font-size: 0.9rem;
		border-top: 1px solid var(--border);
	}
</style>
