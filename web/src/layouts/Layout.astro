---
interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = "/avatar.jpg" } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const tabs = [
	{ href: "/about", label: "About" },
	{ href: "/resume", label: "Resume" },
	{ href: "/projects", label: "Projects" },
	{ href: "/opportunity", label: "Recruiter" },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<title>{title}</title>

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageURL} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />
	</head>
	<body>
		<nav class="site-nav">
			<div class="wrap nav-row">
				<a class="brand" href="/">Matthew Windham</a>

				<!-- Guest nav: shown by default, hidden once auth confirmed -->
				<div class="nav-guest" id="nav-guest">
					<a class="btn-signin" href="/portal/login">Sign In</a>
				</div>

				<!-- Auth nav: hidden by default, shown once auth confirmed -->
				<div class="nav-auth" id="nav-auth" hidden>
					<div class="nav-tabs">
						{tabs.map((tab) => (
							<a
								href={tab.href}
								class={pathname.startsWith(tab.href) ? "active" : ""}
							>
								{tab.label}
							</a>
						))}
						<a href="/portal/admin" id="nav-admin" hidden>Admin</a>
					</div>
					<button type="button" id="nav-signout" class="btn-signout">Sign Out</button>
				</div>
			</div>
		</nav>
		<slot />
		<footer class="wrap">
			<p>Matthew Windham</p>
		</footer>
	</body>
</html>

<script>
	import { getClaims, isAdmin, signOut } from "../lib/auth";

	(async () => {
		const claims = await getClaims();
		const guestNav = document.getElementById("nav-guest")!;
		const authNav = document.getElementById("nav-auth")!;
		const adminLink = document.getElementById("nav-admin") as HTMLAnchorElement;

		if (claims) {
			guestNav.hidden = true;
			authNav.hidden = false;
			if (isAdmin(claims)) adminLink.hidden = false;
		}

		document.getElementById("nav-signout")?.addEventListener("click", signOut);
	})();
</script>

<style is:global>
	:root {
		--bg: #0b0e14;
		--bg-raised: #11151d;
		--border: #1f2733;
		--text: #e6e9ef;
		--text-dim: #92a0b3;
		--accent: #ff9900;
		--mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
		--sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--sans);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	code {
		font-family: var(--mono);
	}

	.wrap {
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.site-nav {
		border-bottom: 1px solid var(--border);
	}

	.nav-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 0;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.brand {
		color: var(--text);
		font-weight: 600;
	}

	.brand:hover {
		text-decoration: none;
		color: var(--accent);
	}

	.nav-guest {
		display: flex;
		align-items: center;
	}

	.btn-signin {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 1.1rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		color: var(--text);
		font-family: var(--mono);
		font-size: 0.85rem;
		font-weight: 500;
		transition: border-color 0.15s, color 0.15s;
	}

	.btn-signin:hover {
		text-decoration: none;
		border-color: var(--accent);
		color: var(--accent);
	}

	.nav-auth {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-tabs {
		display: flex;
		gap: 1.5rem;
		font-family: var(--mono);
		font-size: 0.9rem;
	}

	.nav-tabs a {
		color: var(--text-dim);
	}

	.nav-tabs a.active {
		color: var(--accent);
	}

	.btn-signout {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--text-dim);
		font-family: var(--mono);
		font-size: 0.85rem;
		padding: 0;
		transition: color 0.15s;
	}

	.btn-signout:hover {
		color: var(--accent);
	}

	main {
		padding: 3rem 0;
	}

	section {
		margin-bottom: 3rem;
	}

	h2 {
		font-size: 1.4rem;
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.5rem;
		margin-bottom: 1.5rem;
	}

	blockquote {
		border-left: 2px solid var(--accent);
		margin: 1.5rem 0;
		padding-left: 1rem;
		color: var(--text-dim);
		font-style: italic;
	}

	blockquote cite {
		display: block;
		margin-top: 0.3rem;
		font-style: normal;
		font-size: 0.9rem;
	}

	footer {
		padding: 2rem 0 3rem;
		color: var(--text-dim);
		font-size: 0.9rem;
		border-top: 1px solid var(--border);
	}
</style>
