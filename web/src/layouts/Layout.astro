---
interface Props {
	title: string;
	description: string;
	image?: string;
	requireAuth?: boolean;
}

const { title, description, image = "/avatar.jpg", requireAuth = false } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const navLinks = [
	{ href: "/about", label: "About" },
	{ href: "/resume", label: "Resume" },
	{ href: "/projects", label: "Projects" },
	{ href: "/opportunity", label: "Recruiter" },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<title>{title}</title>

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageURL} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />
		{requireAuth && (
			<script is:inline>document.documentElement.classList.add("auth-pending");</script>
		)}
	</head>
	<body>
		<nav class="site-nav">
			<div class="wrap nav-row">
				<a class="brand" href="/">Matthew Windham</a>

				<div class="nav-links">
					{navLinks.map((link) => (
						<a
							href={link.href}
							class={pathname.startsWith(link.href) ? "active" : ""}
						>
							{link.label}
						</a>
					))}
				</div>

				<!-- Account icon — always the same, no auth state needed -->
				<div class="account-wrap">
					<button
						type="button"
						class="account-btn"
						id="account-btn"
						aria-label="Account menu"
						aria-expanded="false"
						aria-haspopup="true"
					>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
							<circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
							<circle cx="10" cy="7.5" r="3" stroke="currentColor" stroke-width="1.5"/>
							<path d="M3.5 16.5c0-3 3-5 6.5-5s6.5 2 6.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
						</svg>
					</button>

					<div class="account-dropdown" id="account-dropdown" hidden>
						<!-- Loading -->
						<div id="acct-loading" class="acct-loading">
							<span class="loading-dot"></span>
						</div>

						<!-- Logged out -->
						<div id="acct-guest" hidden>
							<a href="/portal/login" class="acct-action">Sign In</a>
							<a href="/portal/register" class="acct-secondary">Create an account</a>
						</div>

						<!-- Logged in -->
						<div id="acct-auth" hidden>
							<p id="acct-name" class="acct-name"></p>
							<hr class="acct-divider" />
							<a href="/portal/settings" class="acct-item">Settings</a>
							<a href="/portal/admin" id="acct-admin" class="acct-item" hidden>Admin inbox</a>
							<button type="button" id="acct-signout" class="acct-item acct-signout">Sign out</button>
						</div>
					</div>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="wrap">
			<p>Matthew Windham</p>
		</footer>
	</body>
</html>

<script>
	import { getClaims, isAdmin, signOut, requireAuth } from "../lib/auth";

	// Centralized auth guard for protected pages
	if (document.documentElement.classList.contains("auth-pending")) {
		(async () => {
			const claims = await requireAuth(window.location.pathname);
			if (claims) document.documentElement.classList.remove("auth-pending");
		})();
	}

	const btn = document.getElementById("account-btn")!;
	const dropdown = document.getElementById("account-dropdown") as HTMLDivElement;
	let loaded = false;

	function openDropdown() {
		dropdown.hidden = false;
		btn.setAttribute("aria-expanded", "true");
		if (!loaded) loadAuth();
	}

	function closeDropdown() {
		dropdown.hidden = true;
		btn.setAttribute("aria-expanded", "false");
	}

	btn.addEventListener("click", (e) => {
		e.stopPropagation();
		dropdown.hidden ? openDropdown() : closeDropdown();
	});

	document.addEventListener("click", (e) => {
		if (!dropdown.hidden && !dropdown.contains(e.target as Node)) closeDropdown();
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") closeDropdown();
	});

	async function loadAuth() {
		const loading = document.getElementById("acct-loading")!;
		const guestEl = document.getElementById("acct-guest")!;
		const authEl = document.getElementById("acct-auth")!;
		const nameEl = document.getElementById("acct-name")!;
		const adminLink = document.getElementById("acct-admin")!;

		const claims = await getClaims();
		loading.hidden = true;

		if (claims) {
			nameEl.textContent = claims.name || claims.email || "";
			if (isAdmin(claims)) adminLink.hidden = false;
			authEl.hidden = false;
		} else {
			guestEl.hidden = false;
		}

		document.getElementById("acct-signout")?.addEventListener("click", () => {
			closeDropdown();
			signOut();
		});

		loaded = true;
	}
</script>

<style is:global>
	:root {
		--bg: #0b0e14;
		--bg-raised: #11151d;
		--border: #1f2733;
		--text: #e6e9ef;
		--text-dim: #92a0b3;
		--accent: #ff9900;
		--mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
		--sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
	}

	html.auth-pending main { visibility: hidden; }

	* { box-sizing: border-box; }

	html, body { margin: 0; padding: 0; }

	body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--sans);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	a { color: var(--accent); text-decoration: none; }
	a:hover { text-decoration: underline; }
	code { font-family: var(--mono); }

	.wrap {
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ── Nav ── */
	.site-nav {
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--bg);
	}

	.nav-row {
		display: flex;
		align-items: center;
		gap: 2rem;
		padding: 1rem 0;
	}

	.brand {
		color: var(--text);
		font-weight: 600;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.brand:hover { text-decoration: none; color: var(--accent); }

	.nav-links {
		display: flex;
		gap: 1.5rem;
		font-family: var(--mono);
		font-size: 0.9rem;
		flex: 1;
	}

	.nav-links a { color: var(--text-dim); }
	.nav-links a:hover { text-decoration: none; color: var(--text); }
	.nav-links a.active { color: var(--accent); }

	/* ── Account dropdown ── */
	.account-wrap {
		position: relative;
		flex-shrink: 0;
	}

	.account-btn {
		background: none;
		border: 1px solid var(--border);
		border-radius: 50%;
		width: 34px;
		height: 34px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		color: var(--text-dim);
		transition: border-color 0.15s, color 0.15s;
		padding: 0;
	}

	.account-btn:hover,
	.account-btn[aria-expanded="true"] {
		border-color: var(--accent);
		color: var(--accent);
	}

	.account-dropdown {
		position: absolute;
		top: calc(100% + 8px);
		right: 0;
		min-width: 200px;
		background: var(--bg-raised);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 0.5rem;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
	}

	.acct-loading {
		display: flex;
		justify-content: center;
		padding: 0.75rem;
	}

	.loading-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		animation: blink 1.2s ease-in-out infinite;
	}

	@keyframes blink {
		0%, 100% { opacity: 0.3; }
		50% { opacity: 1; }
	}

	.acct-name {
		margin: 0;
		padding: 0.4rem 0.6rem;
		font-size: 0.8rem;
		color: var(--text-dim);
		font-family: var(--mono);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.acct-divider {
		border: none;
		border-top: 1px solid var(--border);
		margin: 0.25rem 0;
	}

	.acct-action {
		display: block;
		padding: 0.5rem 0.6rem;
		color: var(--text);
		font-size: 0.9rem;
		border-radius: 5px;
		transition: background 0.15s;
	}

	.acct-action:hover { text-decoration: none; background: var(--border); }

	.acct-secondary {
		display: block;
		padding: 0.4rem 0.6rem;
		color: var(--text-dim);
		font-size: 0.85rem;
		border-radius: 5px;
		transition: background 0.15s;
	}

	.acct-secondary:hover { text-decoration: none; background: var(--border); }

	.acct-item {
		display: block;
		width: 100%;
		text-align: left;
		padding: 0.5rem 0.6rem;
		color: var(--text);
		font-size: 0.9rem;
		background: none;
		border: none;
		border-radius: 5px;
		cursor: pointer;
		font-family: var(--sans);
		transition: background 0.15s;
		text-decoration: none;
	}

	.acct-item:hover { background: var(--border); text-decoration: none; }

	.acct-signout { color: var(--text-dim); }

	/* ── Mobile ── */
	@media (max-width: 600px) {
		.nav-links {
			display: none;
		}
	}

	/* ── Page ── */
	main { padding: 3rem 0; }
	section { margin-bottom: 3rem; }

	h2 {
		font-size: 1.4rem;
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.5rem;
		margin-bottom: 1.5rem;
	}

	blockquote {
		border-left: 2px solid var(--accent);
		margin: 1.5rem 0;
		padding-left: 1rem;
		color: var(--text-dim);
		font-style: italic;
	}

	blockquote cite {
		display: block;
		margin-top: 0.3rem;
		font-style: normal;
		font-size: 0.9rem;
	}

	footer {
		padding: 2rem 0 3rem;
		color: var(--text-dim);
		font-size: 0.9rem;
		border-top: 1px solid var(--border);
	}

	@media print {
		.site-nav,
		footer {
			display: none;
		}

		body {
			background: #fff;
			color: #000;
		}

		a {
			color: #000;
			text-decoration: none;
		}
	}
</style>
